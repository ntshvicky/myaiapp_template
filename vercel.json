{
  "version": 2,
  "framework": null,
  "buildCommand": "pip install -r requirements.txt && python manage.py collectstatic --noinput",
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index" }
  ]
}
